{
  "name": "dspy-slim-ts",
  "version": "0.1.0",
  "description": "Craftsmanship-first TypeScript port of dspy-slim",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "pack:dry-run": "npm pack --dry-run",
    "release:gate": "uv run ../benchmarks/release_gate.py",
    "bench:minimax-policy": "npx tsx tests/minimax_policy_benchmark.ts"
  },
  "devDependencies": {
    "@ax-llm/ax": "^19.0.41",
    "@types/node": "^25.5.2",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
